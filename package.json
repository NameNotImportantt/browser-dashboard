{
  "name": "browser-dashboard",
  "version": "0.1.0",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bunx typed-scss-modules src -w & vite",
    "build": "tsc -b && vite build",
    "build:multi": "tsc -b && vite build --config config/vite/standard.config.ts",
    "start": "vite preview",
    "start:vite": "vite preview --config config/vite/standard.config.ts",
    "lint": "eslint",
    "lint:ts": "eslint \"./src/**/*.{ts,tsx}\"",
    "lint:ts:fix": "eslint \"./src/**/*.{ts,tsx}\" --fix"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "dexie": "^4.2.1",
    "lucide-react": "^1.18.0",
    "react": "^19",
    "react-dom": "^19",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/bun": "latest",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-react": "^7.37.5",
    "sass": "^1.101.0",
    "typed-scss-modules": "^8.1.1",
    "typescript": "^5.9.2",
    "vite": "^8.0.16",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plugin-singlefile": "^2.3.3"
  }
}
